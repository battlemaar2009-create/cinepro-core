{
    "name": "cinepro-core",
    "main": "dist/server.js",
    "compatibility_date": "2026-06-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "workers_dev": true,
    "observability": {
        "enabled": true
    },
    "vars": {
        "NODE_ENV": "production",
        "CACHE_TYPE": "memory",
        "STREMIO_ADDON": "true",
        "CORS_ORIGIN": "*",
        "MCP_ENABLED": "true"
    },
    "build": {
        "command": "npm install && npm run build"
    }
}
